rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: tenants
    // Fields: name, lat, lng, radius, status, subscription_plan, createdAt
    //
    // Collection: users
    // Fields: name, email, role, tenant_id, face_descriptor, createdAt
    //
    // Collection: attendance
    // Fields: tenant_id, user_id, check_in, check_out, lat, lng, photo_url, status, rejection_reason
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "altamedia7@gmail.com" || 
         request.auth.token.email == "iruelpraker@gmail.com" ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SUPER_ADMIN'));
    }

    function isAdmin() {
      return isAuthenticated() && 
        (isSuperAdmin() || 
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN'));
    }

    function isTenantAdmin(tenantId) {
      return isAuthenticated() && 
        (isSuperAdmin() || 
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenant_id == tenantId && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN'));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Tenants
    match /tenants/{tenantId} {
      allow read: if isAuthenticated();
      allow create, delete: if isSuperAdmin();
      allow update: if isSuperAdmin() || (isTenantAdmin(tenantId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'check_in_time', 'check_in_end_time', 'check_out_time', 'check_out_end_time', 'off_days', 'is_journal_enabled']));
    }

    // Users
    match /users/{userId} {
      allow get: if isAuthenticated() && (request.auth.uid == userId || isSuperAdmin() || isAdmin());
      allow list: if isSuperAdmin() || isAdmin();
      allow create: if isAuthenticated() && (request.auth.uid == userId || isSuperAdmin() || isTenantAdmin(request.resource.data.tenant_id));
      allow update: if isAuthenticated() && (
        (request.auth.uid == userId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'phone', 'nip_nis', 'address', 'face_descriptor', 'face_image_url'])) || 
        isAdmin() || 
        isSuperAdmin()
      );
      allow delete: if isSuperAdmin() || isTenantAdmin(resource.data.tenant_id);
    }

    // Attendance
    match /attendance/{attendanceId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.user_id || 
        isTenantAdmin(resource.data.tenant_id) || 
        isSuperAdmin()
      );
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      allow update: if isAuthenticated() && (
        request.auth.uid == resource.data.user_id || 
        isTenantAdmin(resource.data.tenant_id) || 
        isSuperAdmin()
      );
      allow delete: if isSuperAdmin();
    }

    // Journals
    match /journals/{journalId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.user_id || 
        isTenantAdmin(resource.data.tenant_id) || 
        isSuperAdmin()
      );
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      allow update: if isAuthenticated() && (
        request.auth.uid == resource.data.user_id || 
        isTenantAdmin(resource.data.tenant_id) || 
        isSuperAdmin()
      );
      allow delete: if isSuperAdmin();
    }

    // Holidays
    match /holidays/{holidayId} {
      allow read: if isAuthenticated();
      allow create: if isSuperAdmin() || isTenantAdmin(request.resource.data.tenant_id);
      allow update, delete: if isSuperAdmin() || isTenantAdmin(resource.data.tenant_id);
    }

    // Announcements
    match /announcements/{announcementId} {
      allow read: if isAuthenticated();
      allow create: if isSuperAdmin() || isTenantAdmin(request.resource.data.tenant_id);
      allow update, delete: if isSuperAdmin() || isTenantAdmin(resource.data.tenant_id);
    }
  }
}
