{
  "entities": {
    "tenant": {
      "title": "Tenant",
      "description": "A school or company using the attendance system.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the school or company" },
        "lat": { "type": "number", "description": "Latitude of the center point" },
        "lng": { "type": "number", "description": "Longitude of the center point" },
        "radius": { "type": "number", "description": "Allowed radius in meters" },
        "status": { "type": "string", "enum": ["active", "inactive"], "description": "Subscription status" },
        "subscription_plan": { "type": "string", "description": "Plan name" },
        "check_in_time": { "type": "string" },
        "check_in_end_time": { "type": "string" },
        "check_out_time": { "type": "string" },
        "check_out_end_time": { "type": "string" },
        "off_days": { 
          "type": "array", 
          "items": { "type": "number" },
          "description": "Weekly off days (0=Sun, 1=Mon, ..., 6=Sat)"
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "lat", "lng", "radius", "status"]
    },
    "user": {
      "title": "User",
      "description": "A person belonging to a tenant.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["ADMIN", "USER", "SUPER_ADMIN"] },
        "tenant_id": { "type": "string" },
        "face_descriptor": { "type": "array", "description": "Serialized face descriptor array" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "role", "tenant_id"]
    },
    "attendance": {
      "title": "Attendance",
      "description": "An attendance record for a user.",
      "type": "object",
      "properties": {
        "tenant_id": { "type": "string" },
        "user_id": { "type": "string" },
        "check_in": { "type": "string", "format": "date-time" },
        "check_out": { "type": "string", "format": "date-time" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "photo_url": { "type": "string" },
        "status": { "type": "string", "enum": ["valid", "rejected", "suspicious"] },
        "is_late": { "type": "boolean", "description": "Whether the user was late" },
        "rejection_reason": { "type": "string" }
      },
      "required": ["tenant_id", "user_id", "check_in", "status"]
    },
    "holiday": {
      "title": "Holiday",
      "description": "A holiday date for a tenant.",
      "type": "object",
      "properties": {
        "tenant_id": { "type": "string" },
        "date": { "type": "string", "description": "Date in YYYY-MM-DD format" },
        "name": { "type": "string", "description": "Name of the holiday" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tenant_id", "date", "name"]
    },
    "student": {
      "title": "Student",
      "description": "A student in a class.",
      "type": "object",
      "properties": {
        "tenant_id": { "type": "string" },
        "name": { "type": "string" },
        "nis": { "type": "string", "description": "Nomor Induk Siswa" },
        "class_name": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tenant_id", "name", "class_name"]
    },
    "schedule": {
      "title": "Schedule",
      "description": "A teaching schedule for a teacher.",
      "type": "object",
      "properties": {
        "tenant_id": { "type": "string" },
        "user_id": { "type": "string", "description": "Teacher ID" },
        "subject": { "type": "string" },
        "class_name": { "type": "string" },
        "day": { "type": "number", "description": "0=Sun, 1=Mon, ..., 6=Sat" },
        "start_time": { "type": "string" },
        "end_time": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tenant_id", "user_id", "subject", "class_name", "day", "start_time", "end_time"]
    },
    "student_attendance": {
      "title": "Student Attendance",
      "description": "Attendance record for a student in a specific session.",
      "type": "object",
      "properties": {
        "tenant_id": { "type": "string" },
        "schedule_id": { "type": "string" },
        "student_id": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["H", "S", "I", "A"] },
        "note": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tenant_id", "schedule_id", "student_id", "date", "status"]
    },
    "grade": {
      "title": "Grade",
      "description": "A grade for a student.",
      "type": "object",
      "properties": {
        "tenant_id": { "type": "string" },
        "student_id": { "type": "string" },
        "subject": { "type": "string" },
        "type": { "type": "string", "description": "Tugas, UH, UTS, UAS, etc." },
        "score": { "type": "number" },
        "date": { "type": "string", "format": "date" },
        "teacher_id": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tenant_id", "student_id", "subject", "score", "teacher_id"]
    }
  },
  "firestore": {
    "/tenants/{tenantId}": {
      "schema": "tenant",
      "description": "Collection of tenants"
    },
    "/users/{userId}": {
      "schema": "user",
      "description": "Collection of users"
    },
    "/attendance/{attendanceId}": {
      "schema": "attendance",
      "description": "Collection of attendance logs"
    },
    "/holidays/{holidayId}": {
      "schema": "holiday",
      "description": "Collection of holidays"
    },
    "/students/{studentId}": {
      "schema": "student",
      "description": "Collection of students"
    },
    "/schedules/{scheduleId}": {
      "schema": "schedule",
      "description": "Collection of teaching schedules"
    },
    "/student_attendance/{id}": {
      "schema": "student_attendance",
      "description": "Collection of student attendance"
    },
    "/grades/{gradeId}": {
      "schema": "grade",
      "description": "Collection of student grades"
    }
  }
}
